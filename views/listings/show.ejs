<% layout("/layouts/boilerplate") %>
<script>
    const mapToken = "<%= process.env.MAP_TOKEN %>";
    const listing = <%- JSON.stringify(listing) %>;
</script>
<body>
    <div class="row mt-4 mb-5">
        <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2">
            <h2 class="mb-4 fw-bold"><%= listing.title %></h2>
            
            <div class="card border-0 shadow-sm overflow-hidden mb-4" style="border-radius: 1.5rem;">
                <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 60vh; object-fit: cover; border-radius: 0;">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <p class="text-secondary mb-0"><i class="fa-regular fa-circle-user me-2"></i>Hosted by <b><%= listing.owner.username %></b></p>
                        <span class="badge bg-light text-dark border px-3 py-2" style="border-radius: 2rem;"><i class="fa-solid fa-location-dot me-2 text-primary"></i><%= listing.location %>, <%= listing.country %></span>
                    </div>
                    
                    <hr class="my-4 opacity-75">
                    
                    <h5 class="fw-bold mb-3">About this place</h5>
                    <p class="card-text text-secondary fs-5" style="line-height: 1.6;"><%= listing.description %></p>
                    
                    <div class="d-flex align-items-center mt-4">
                        <span class="fs-2 fw-bold text-dark">&#x20B9;<%= listing.price.toLocaleString("en-IN") %></span>
                        <span class="text-secondary ms-2">/ night</span>
                    </div>

                    <% if(currUser && currUser._id.equals(listing.owner._id)){ %>
                        <div class="d-flex gap-2 mt-4 pt-2">
                            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark px-4 py-2 border-0" style="background: #222; border-radius: 0.75rem;">Edit</a>
                            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                                <button class="btn btn-danger px-4 py-2 border-0" style="background: var(--primary); border-radius: 0.75rem;">Delete</button>
                            </form>
                        </div>
                    <% } %>
                </div>
            </div>

            <hr class="my-5 opacity-75">

            <div class="row">
                <div class="col-12 col-lg-5 mb-4 mb-lg-0">
                    <% if(currUser){ %>
                        <h4 class="mb-4 fw-bold">Leave a Review</h4>
                        <form method="POST" action="/listings/<%= listing._id %>/reviews" novalidate class="needs-validation bg-white p-4 rounded-4 border shadow-sm">
                            <div class="mb-4">
                                <label for="rating" class="form-label fw-medium text-secondary">Rating</label>
                                <fieldset class="starability-slot border-0 p-0 m-0">
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>

                            <div class="mb-3">
                                <label for="comment" class="form-label fw-medium text-secondary">Your Comment</label>
                                <textarea name="review[comment]" id="comment" rows="4" class="form-control bg-light border-0 px-3 py-2" placeholder="Tell us about your stay..." required style="border-radius: 0.75rem;"></textarea>
                                <div class="invalid-feedback">Please share your experience.</div>
                            </div>
                            
                            <button class="btn btn-search w-100 py-2 mt-3">Submit Review</button>
                        </form>
                    <% } %>
                </div>

                <div class="col-12 col-lg-7">
                    <% if(listing.reviews.length > 0){ %>
                        <h4 class="mb-4 fw-bold">All Reviews</h4>
                        <div class="row g-3">
                            <% for(let review of listing.reviews){ %>
                                <div class="col-12 col-md-6">
                                    <div class="card h-100 border-0 shadow-sm p-3 rounded-4 bg-white">
                                        <div class="card-body p-0">
                                            <div class="d-flex align-items-center mb-2">
                                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-2" style="width: 32px; height: 32px; font-size: 0.8rem;"><%= review.author.username[0].toUpperCase() %></div>
                                                <h6 class="mb-0 fw-bold text-dark"><%= review.author.username %></h6>
                                            </div>
                                            <p class="starability-result mb-2" data-rating="<%= review.rating %>" style="transform: scale(0.65); origin: left;"></p>
                                            <p class="card-text text-secondary small mb-3"><%= review.comment %></p>
                                            
                                            <form class="text-end" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                                                <button class="btn btn-sm btn-link text-danger text-decoration-none p-0 fw-medium">Delete</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            </div>

            <hr class="my-5 opacity-75">

            <div class="mb-5">
                <h4 class="fw-bold mb-4">Where you'll be</h4>
                <div id="map" class="shadow-sm"></div>
            </div>
        </div>
    </div>

    <script src="/js/map.js"></script>
</body>