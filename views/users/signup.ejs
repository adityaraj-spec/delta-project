<% layout("/layouts/boilerplate") %>
<body>
    <div class ="row mt-3">
        <h1 class="col-8 offset-3">
             SignUp on Wanderlust</h1>
       <div class="col-8 offset-3">
            <form method= "POST" action="/signup" novalidate class ="needs-validation" >
                <div  class = "mb-3">
                    <label for="username"  class ="form-label" >Username</label>
                    <input name = "username" id ="username" type="text" placeholder="Enter a valid username" class ="form-control" required> 
                    <div class="valid-feedback">Looks good!</div>  
                </div>

                <div class = "mb-3 ">
                    <label for="email" class ="form-label" >Email</label>
                    <input name = "email"  id =" email"type="email" placeholder="Enter a valid email" class ="form-control" required></input>
                </div>

                <div class = "mb-3 ">
                    <label for="password" class ="form-label" >Password</label>
                    <input name = "password"  id ="password"type="password" placeholder="Enter a valid password" class ="form-control" required></input>
                </div>
                <button class = "btn btn-dark mb-3 add-btn">SignUp</button>
            </form>
       </div>
    </div>
</body>